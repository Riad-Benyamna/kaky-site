<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600&family=Instrument+Serif:ital@1&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg: #0C0B09;
    --card: #181512;
    --elevated: #252118;
    --orange: #FF6B35;
    --warm-white: #F0EDE8;
    --mid: #6B635C;
    --dim: #2E2A26;
    --border: rgba(240,237,232,0.07);
  }

  html { scroll-behavior: smooth; }

  body {
    background: var(--bg);
    color: var(--warm-white);
    font-family: 'DM Sans', sans-serif;
    font-weight: 300;
    line-height: 1.7;
    min-height: 100vh;
  }

  /* Subtle background texture */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background:
      radial-gradient(ellipse 60% 40% at 80% 10%, rgba(255,107,53,0.06) 0%, transparent 60%),
      radial-gradient(ellipse 50% 60% at 10% 80%, rgba(255,107,53,0.03) 0%, transparent 60%);
    pointer-events: none;
    z-index: 0;
  }

  .container {
    position: relative;
    z-index: 1;
    max-width: 720px;
    margin: 0 auto;
    padding: 0 24px 80px;
  }

  /* Header */
  header {
    padding: 56px 0 48px;
    border-bottom: 1px solid var(--border);
    margin-bottom: 48px;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 32px;
    text-decoration: none;
  }

  .logo-icon {
    width: 36px;
    height: 36px;
    background: var(--orange);
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .logo-icon svg {
    width: 20px;
    height: 20px;
  }

  .logo-name {
    font-size: 18px;
    font-weight: 600;
    color: var(--warm-white);
    letter-spacing: -0.01em;
  }

  .page-label {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--orange);
    margin-bottom: 12px;
  }

  h1 {
    font-size: clamp(28px, 5vw, 40px);
    font-weight: 300;
    letter-spacing: -0.02em;
    color: var(--warm-white);
    line-height: 1.2;
    margin-bottom: 16px;
  }

  h1 em {
    font-family: 'Instrument Serif', serif;
    font-style: italic;
    color: var(--orange);
    font-weight: 400;
  }

  .meta {
    font-size: 13px;
    color: var(--mid);
    font-weight: 400;
  }

  /* Table of contents */
  .toc {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 24px 28px;
    margin-bottom: 48px;
  }

  .toc-title {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--mid);
    margin-bottom: 16px;
  }

  .toc-list {
    list-style: none;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6px 24px;
  }

  @media (max-width: 480px) {
    .toc-list { grid-template-columns: 1fr; }
  }

  .toc-list a {
    font-size: 13px;
    color: var(--mid);
    text-decoration: none;
    font-weight: 400;
    transition: color 0.15s;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .toc-list a:hover { color: var(--orange); }

  .toc-list a::before {
    content: attr(data-num);
    font-size: 10px;
    color: var(--dim);
    font-weight: 500;
    min-width: 16px;
  }

  /* Sections */
  .section {
    margin-bottom: 40px;
    scroll-margin-top: 24px;
  }

  .section-header {
    display: flex;
    align-items: baseline;
    gap: 12px;
    margin-bottom: 16px;
  }

  .section-num {
    font-size: 11px;
    font-weight: 500;
    color: var(--orange);
    letter-spacing: 0.05em;
    flex-shrink: 0;
    padding-top: 2px;
  }

  h2 {
    font-size: 16px;
    font-weight: 600;
    color: var(--warm-white);
    letter-spacing: -0.01em;
  }

  p {
    font-size: 14px;
    color: rgba(240,237,232,0.7);
    margin-bottom: 12px;
    font-weight: 300;
  }

  p:last-child { margin-bottom: 0; }

  ul {
    list-style: none;
    margin: 8px 0 12px;
  }

  ul li {
    font-size: 14px;
    color: rgba(240,237,232,0.7);
    font-weight: 300;
    padding: 5px 0 5px 20px;
    position: relative;
  }

  ul li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 14px;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--orange);
    opacity: 0.5;
  }

  /* Callout box */
  .callout {
    background: rgba(255,107,53,0.07);
    border: 1px solid rgba(255,107,53,0.18);
    border-radius: 12px;
    padding: 16px 20px;
    margin: 16px 0;
  }

  .callout p {
    color: rgba(240,237,232,0.8);
    margin: 0;
    font-size: 13.5px;
  }

  /* Divider */
  .divider {
    height: 1px;
    background: var(--border);
    margin: 40px 0;
  }

  /* Contact section */
  .contact-card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 28px;
  }

  .contact-card h2 {
    margin-bottom: 12px;
  }

  .contact-card p {
    margin-bottom: 6px;
  }

  .contact-card a {
    color: var(--orange);
    text-decoration: none;
    font-weight: 400;
  }

  .contact-card a:hover {
    text-decoration: underline;
  }

  /* Footer */
  footer {
    margin-top: 64px;
    padding-top: 24px;
    border-top: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 12px;
  }

  footer p {
    font-size: 12px;
    color: var(--mid);
    margin: 0;
  }

  footer a {
    color: var(--mid);
    text-decoration: none;
    transition: color 0.15s;
  }

  footer a:hover { color: var(--orange); }
</style>
</head>
